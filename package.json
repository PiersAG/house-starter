{
  "name": "house-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:isolation": "vitest run tests/unit/db.test.ts && playwright test --project=isolation",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:all-tenants": "tsx scripts/migrate-all-tenants.ts",
    "db:verify-tenant-backups": "tsx scripts/verify-tenant-backups.ts",
    "db:push": "drizzle-kit push",
    "prepare": "husky"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@radix-ui/react-slot": "1.2.5",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "0.460.0",
    "next": "15.5.19",
    "next-auth": "5.0.0-beta.28",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "2.5.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/forms": "0.5.9",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@typescript-eslint/eslint-plugin": "8.0.1",
    "@typescript-eslint/parser": "8.0.1",
    "@vitejs/plugin-react-swc": "3.11.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "autoprefixer": "10.4.20",
    "dotenv": "^17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.0.0",
    "eslint-config-next": "15.5.19",
    "husky": "9.1.7",
    "jsdom": "25.0.1",
    "lint-staged": "15.5.2",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "3.4.19",
    "tsx": "4.22.4",
    "typescript": "5.6.3",
    "vitest": "4.1.8"
  },
  "overrides": {
    "vite": "6.4.3",
    "form-data": "4.0.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
