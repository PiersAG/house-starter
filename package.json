    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "0.460.0",
    "next": "15.5.19",
    "next-auth": "5.0.0-beta.28",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "2.5.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "22.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "tailwindcss": "3.4.19",
    "@tailwindcss/forms": "0.5.9",
    "autoprefixer": "10.4.20",
