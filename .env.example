# Copy to .env.local and fill in values before running the app.
# NEVER commit .env.local. Only this .env.example (with empty values) is tracked.

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (libSQL / Turso — same driver across dev/test/staging/prod)
# ─────────────────────────────────────────────────────────────────────────────
# The ONLY thing that changes between environments is this URL.
#   • dev:   file:local.db          (local file on disk; no auth token needed)
#   • test:  :memory:               (set by the test setup, not here)
#   • prod:  libsql://<db>-<org>.turso.io   (hosted; REQUIRES the auth token below)
#
# Leave DATABASE_URL empty for the default dev file (file:local.db). Set it
# explicitly to the hosted libsql:// URL in staging/prod.
DATABASE_URL=

# Production database auth token. HIGH-VALUE SECRET — full read/write to the
# production database.
#   • dev (file:local.db): leave EMPTY.
#   • prod: set ONLY in the host's secret store (e.g. Vercel env vars). NEVER
#     paste a real token into this file, .env.local, or any committed file.
DATABASE_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# DATA PROTECTION (read before deploying to a new market)
# ─────────────────────────────────────────────────────────────────────────────
# • DATA RESIDENCY is PER-APP, set by the app's target market — not a global
#   default. Provision the hosted database in a region appropriate to where the
#   app's users are (e.g. UK/EU region for UK/EU users, US region for US users).
#   Residency is the one control where "strictest regime wins" does NOT apply.
# • IN-TRANSIT: the prod URL MUST use a TLS scheme (libsql:// / https:// — TLS on
#   by default). NEVER append ?tls=0 in staging or prod.
# • CROSS-BORDER: personal data stays in-region. Only anonymised/aggregated data
#   (counts, metrics, revenue) should flow back to the central UK dashboard — a
#   raw personal-data pull to the UK is an international transfer needing a
#   separate lawful basis, which TLS alone does NOT provide.
# • AT-REST: prefer a host that encrypts at rest; libSQL also supports an
#   encryptionKey option for local/file encryption if required by the market.

# ─────────────────────────────────────────────────────────────────────────────
# AUTH (NextAuth)
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Alias of AUTH_SECRET — same value.
NEXTAUTH_SECRET=
# App URL (required in production), e.g. https://your-app.vercel.app
NEXTAUTH_URL=

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (optional, configure at MVP boundary)
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
