# Copy to .env.local and fill in values before running the app.
# Never commit .env.local to git.

# Database connection (Drizzle ORM)
DATABASE_URL=

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=
# NEXTAUTH_SECRET= (alias, same value)
NEXTAUTH_SECRET=

# App URL (required in production)
NEXTAUTH_URL=

# Error tracking (configure at MVP boundary)
SENTRY_DSN=
